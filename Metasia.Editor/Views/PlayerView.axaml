<UserControl	xmlns="https://github.com/avaloniaui"
			xmlns:controls="clr-namespace:Metasia.Editor.Controls"
			xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			xmlns:vm="using:Metasia.Editor.ViewModels"
			xmlns:views="clr-namespace:Metasia.Editor.Views"
			xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			x:Class="Metasia.Editor.Views.PlayerView"
			x:DataType="vm:PlayerViewModel">
	<DockPanel>
		
		<StackPanel DockPanel.Dock="Bottom" Margin="4">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="{Binding CurrentTime}" VerticalAlignment="Center" Margin="0,0,8,0" FontFamily="monospace"/>
				<controls:PlayerSlider TickPlacement="None" Grid.Column="1" 
						Minimum="{Binding SliderMinimum}" Maximum="{Binding SliderMaximum}" Value="{Binding Frame}"
                        TrackThickness="10"
						SelectStartValue="{Binding SliderSelectionStart}" SelectEndValue="{Binding SliderSelectionEnd}" Padding="4"/>
				<StackPanel Grid.Column="2" Orientation="Horizontal">
					<Button Height="32" IsVisible="{Binding !IsPlaying}"
							Command="{Binding Play}">
						<PathIcon Data="{StaticResource play_regular}" />
					</Button>
					<Button Height="32" IsVisible="{Binding IsPlaying}"
							Command="{Binding Pause}">
						<PathIcon Data="{StaticResource pause_regular}" />
					</Button>
					<Button Height="32" Content="＜" Command="{Binding PreviousFrame}"/>
					<Button Height="32" Content="＞" Command="{Binding NextFrame}"/>
					<Button Height="32" Content="|&lt;" Command="{Binding SetSelectionStart}"/>
					<Button Height="32" Content="&gt;|" Command="{Binding SetSelectionEnd}"/>
				</StackPanel>
				
			</Grid>

		</StackPanel>

		<Panel>
			<controls:SkiaGpuControl Name="skiaCanvas"
				VerticalAlignment="Stretch"
				HorizontalAlignment="Stretch"/>
		</Panel>
	</DockPanel>
</UserControl>
