<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Metasia.Editor.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:Metasia.Editor.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Metasia.Editor.Views.TimelineView"
			 x:DataType="vm:TimelineViewModel">
	<Grid RowDefinitions="*">
		<Grid Grid.Row="0" ColumnDefinitions="100,1,*">
			<Grid Grid.Column="0" RowDefinitions="50,1,*">
				<ScrollViewer x:Name="LayerButtonScroll"
				              Grid.Row="2" AllowAutoHide="True" VerticalScrollBarVisibility="Hidden">
					<ItemsControl ItemsSource="{Binding LayerButtons}"/>
				</ScrollViewer>
			</Grid>
			<GridSplitter Grid.Column="1" Background="Transparent"/>
			<Grid Grid.Column="2" RowDefinitions="50,1,*">
				<ScrollViewer x:Name="TimescaleScroll"
				              HorizontalScrollBarVisibility="Hidden"
				              Grid.Row="0">
					<Canvas x:Name="TimecodeCanvas" Width="{Binding TimelineWidth}"
						PointerPressed="TimecodeCanvas_PointerPressed"
						PointerMoved="TimecodeCanvas_PointerMoved"
						PointerReleased="TimecodeCanvas_PointerReleased">
					<controls:TimeRulerControl Width="{Binding TimelineWidth}" Height="50"
												   MinTextInterval="50"
					                           FramePerDIP="{Binding Frame_Per_DIP}"
					                           FrameRate="{Binding FrameRate}"/>
						<Rectangle Canvas.Left="0" Width="{Binding InvalidStartWidth}" Height="500"
								   Fill="#50808080" IsHitTestVisible="False"
								   IsVisible="{Binding HasInvalidStart}"/>
						<Rectangle Canvas.Left="{Binding InvalidEndLeft}" Width="50000" Height="500"
								   Fill="#50808080" IsHitTestVisible="False"
								   IsVisible="{Binding HasInvalidEnd}"/>
						<Rectangle Canvas.Left="{Binding CursorLeft}" Fill="Red" Width="2" Height="500" IsHitTestVisible="False"/>
					</Canvas>
					
				</ScrollViewer>
				<ScrollViewer x:Name="LinesScroll"
				              VerticalScrollBarVisibility="Hidden"
				              HorizontalScrollBarVisibility="Hidden"
				              Grid.Row="2">
					<Canvas x:Name="TimelineCanvas" VerticalAlignment="Top"
							Width="{Binding ElementName=TimelineScroll, Path=Bounds.Width}"
					        Height="{Binding ElementName=TimelineScroll, Path=Bounds.Height}"
							PointerPressed="TimelineCanvas_PointerPressed"
							PointerMoved="TimelineCanvas_PointerMoved"
							PointerReleased="TimelineCanvas_PointerReleased">
						<Rectangle Canvas.Left="0" Width="{Binding InvalidStartWidth}" Height="5000"
								   Fill="#50808080" IsHitTestVisible="False" ZIndex="2"
								   IsVisible="{Binding HasInvalidStart}"/>
						<Rectangle Canvas.Left="{Binding InvalidEndLeft}" Width="50000" Height="5000"
								   Fill="#50808080" IsHitTestVisible="False" ZIndex="2"
								   IsVisible="{Binding HasInvalidEnd}"/>
						<Rectangle Canvas.Left="{Binding CursorLeft}" Fill="Red" Width="2" Height="5000" ZIndex="1" IsHitTestVisible="False"/>
						<ItemsControl x:Name="TimelineScroll" ItemsSource="{Binding LayerCanvas}" />
					</Canvas>

				</ScrollViewer>
			</Grid>
		</Grid>
	</Grid>
	
</UserControl>
