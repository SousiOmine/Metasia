<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Metasia.Editor.ViewModels.Timeline"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="30"
             x:Class="Metasia.Editor.Views.Timeline.ClipView"
			 x:DataType="vm:ClipViewModel"
             xmlns:converter="clr-namespace:Metasia.Editor.Views.BindingConverter"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
             xmlns:behaviors="clr-namespace:Metasia.Editor.Views.Behaviors"
             xmlns:timelineVm="using:Metasia.Editor.ViewModels.Timeline"
			 Width="{Binding Width}" VerticalAlignment="Stretch">
	<UserControl.Resources>
		<converter:ClipSelectConverter x:Key="ClipConverter"/>
	</UserControl.Resources>
	<Border x:Name="Clip" 
			BorderBrush="Transparent" Background="{Binding ClipColor}" BorderThickness="1" CornerRadius="10" ClipToBounds="True"
	        Opacity="{Binding IsSelecting, Converter={StaticResource ClipConverter}}"
			>
		<i:Interaction.Behaviors>
			<behaviors:ClipViewBehavior DragThreshold="5" FramePerDIP="{Binding Frame_Per_DIP}"/>
		</i:Interaction.Behaviors>
		<Grid ColumnDefinitions="Auto,*,Auto">
			<ItemsControl Grid.ColumnSpan="3"
			              ItemsSource="{Binding MidpointMarkers}"
			              VerticalAlignment="Stretch"
			              HorizontalAlignment="Stretch"
			              ZIndex="5">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<Canvas/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemContainerTheme>
					<ControlTheme x:DataType="timelineVm:ClipMidpointMarkerViewModel" TargetType="ContentPresenter">
						<Setter Property="Canvas.Left" Value="{Binding Left}" />
						<Setter Property="Canvas.Top" Value="{Binding Top}" />
					</ControlTheme>
				</ItemsControl.ItemContainerTheme>
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="timelineVm:ClipMidpointMarkerViewModel">
						<Border Width="{Binding Width}"
						        Height="{Binding Height}"
						        Background="#FFFFFFFF"
						        BorderBrush="#FF000000"
						        BorderThickness="1"
						        CornerRadius="1"
						        Cursor="SizeWestEast"
						        RenderTransformOrigin="0.5,0.5">
							<Border.RenderTransform>
								<RotateTransform Angle="45"/>
							</Border.RenderTransform>
							<i:Interaction.Behaviors>
								<behaviors:ClipMidpointMarkerBehavior/>
							</i:Interaction.Behaviors>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<Border Grid.Column="0" x:Name="StartHandle" Width="10" Background="Transparent" Cursor="SizeWestEast" VerticalAlignment="Stretch" HorizontalAlignment="Left"/>
			<RelativePanel Grid.Column="1">
				<TextBlock Text="{Binding DisplayName}" Padding="5" RelativePanel.AlignVerticalCenterWithPanel="True"/>
			</RelativePanel>
			<Border Grid.Column="2" x:Name="EndHandle" Width="10" Background="Transparent" Cursor="SizeWestEast" VerticalAlignment="Stretch" HorizontalAlignment="Right"/>
		</Grid>
		
		<Border.ContextFlyout>
			<MenuFlyout>
				<MenuItem Header="コピー" Command="{Binding CopyCommand}" />
				<MenuItem Header="切り取り" Command="{Binding CutCommand}" />
				<MenuItem Header="貼り付け" Command="{Binding PasteCommand}" />
				<Separator/>
				<MenuItem Header="分割" Command="{Binding SplitClipCommand}" />
				<MenuItem Header="削除" Command="{Binding RemoveClipCommand}" />
				<MenuItem Header="テンプレートファイルを出力" Command="{Binding ExportTemplateCommand}" />
			</MenuFlyout>
		</Border.ContextFlyout>
	</Border>
</UserControl>
