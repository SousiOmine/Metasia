<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Metasia.Editor.ViewModels.Settings"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="Metasia.Editor.Views.Settings.GeneralSettingsView"
             x:DataType="vm:GeneralSettingsViewModel">
    <ScrollViewer>
        <StackPanel Spacing="10">
        <StackPanel Spacing="5">
            <TextBlock Text="言語"/>
            <ComboBox ItemsSource="{Binding LanguageOptions}"
                      SelectedItem="{Binding SelectedLanguage}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="5">
            <TextBlock Text="エディタの表示テーマ"/>
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedTheme}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <CheckBox Content="自動セーブ" ToolTip.Tip="有効にすると、開いているプロジェクトを定期的に上書き保存します。"
                  IsChecked="{Binding AutoSave}"/>

        <StackPanel Spacing="5">
            <TextBlock Text="自動セーブの実行間隔 (分)"/>
            <NumericUpDown Value="{Binding AutoSaveInterval}" Minimum="1" Maximum="60" Increment="1"/>
        </StackPanel>

        <Separator Margin="0,10"/>

        <CheckBox Content="自動バックアップ" ToolTip.Tip="有効にすると、開いているプロジェクトを定期的にバックアップフォルダに保存します。"
                  IsChecked="{Binding AutoBackup}"/>

        <StackPanel Spacing="5">
            <TextBlock Text="自動バックアップの実行間隔 (分)"/>
            <NumericUpDown Value="{Binding AutoBackupInterval}" Minimum="1" Maximum="120" Increment="1"/>
        </StackPanel>

        <StackPanel Spacing="5">
            <TextBlock Text="バックアップ先のパス"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Text="{Binding AutoBackupPath}"
                         Watermark="バックアップ先のパスを指定..."
                         Grid.Column="0"/>
                <Button Content="..."
                        Command="{Binding SelectBackupPathCommand}"
                        Width="40"
                        Margin="5,0,0,0"
                        Grid.Column="1"/>
            </Grid>
        </StackPanel>

        <StackPanel Spacing="5">
            <TextBlock Text="バックアップ数の上限"/>
            <NumericUpDown Value="{Binding AutoBackupMaxCount}" Minimum="1" Maximum="100" Increment="1"/>
        </StackPanel>

        <Separator Margin="0,10"/>

        <StackPanel Spacing="5">
            <TextBlock Text="メディアファイル参照の保存形式"
                       ToolTip.Tip="動画や音声など外部ファイルを指定するオブジェクトにおいて、パスを相対パスと絶対パスのどちらで保存するかを指定します。この設定は新たな編集にのみ適用されます。"/>
            <ComboBox ToolTip.Tip="動画や音声など外部ファイルを指定するオブジェクトにおいて、パスを相対パスと絶対パスのどちらで保存するかを指定します。この設定は新たな編集にのみ適用されます。"
                      ItemsSource="{Binding MediaPathStyleOptions}"
                      SelectedItem="{Binding SelectedMediaPathStyle}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
    </StackPanel>
    </ScrollViewer>
</UserControl>
