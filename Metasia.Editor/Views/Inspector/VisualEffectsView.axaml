<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Metasia.Editor.ViewModels.Inspector"
             xmlns:inspector="clr-namespace:Metasia.Editor.Views.Inspector"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
             x:Class="Metasia.Editor.Views.Inspector.VisualEffectsView"
             x:DataType="vm:VisualEffectsViewModel">
    <StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="+" Command="{Binding NewEffectCommand}"/>
            <Button Content="-" Command="{Binding DeleteEffectCommand}"/>
        </StackPanel>
        <ListBox
            ItemsSource="{Binding VisualEffectItems}"
            SelectedItem="{Binding SelectedVisualEffectItem}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:VisualEffectItemViewModel" x:DataType="vm:VisualEffectItemViewModel">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
                        <CheckBox Grid.Column="0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding IsActive}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding EffectName}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="2"
                                Padding="6,2"
                                Content="▲"
                                Command="{Binding MoveUpCommand}"
                                IsEnabled="{Binding CanMoveUp}"/>
                        <Button Grid.Column="3"
                                Padding="6,2"
                                Content="▼"
                                Command="{Binding MoveDownCommand}"
                                IsEnabled="{Binding CanMoveDown}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ItemsControl ItemsSource="{Binding Properties}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:PropertyRouterViewModel">
                    <inspector:PropertyRouterView/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
